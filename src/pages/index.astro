---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Features from '../components/Features.astro';
import Differentiator from '../components/Differentiator.astro';
import Screenshots from '../components/Screenshots.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="CutPhase — Phase-Based Dieting App"
  description="CutPhase structures your nutrition into cutting, bulking, and maintenance phases—so your diet actually aligns with your goals."
>
  <Header />
  <main>
    <Hero />
    <Problem />
    <HowItWorks />
    <Features />
    <Differentiator />
    <Screenshots />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
