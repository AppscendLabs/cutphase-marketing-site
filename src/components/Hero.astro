---
---

<section class="hero" aria-label="Hero">
  <div class="container">
    <div class="hero-inner">

      <div class="hero-text">
        <span class="label">Introducing CutPhase</span>
        <h1>Your Diet Should Match Your <em>Phase.</em></h1>
        <p class="hero-sub">
          CutPhase structures your nutrition into cutting, bulking, and maintenance
          phases—so your diet actually aligns with your goals.
        </p>
        <div class="hero-actions">
          <a href="https://apps.apple.com/us/app/cutphase/id6756089854" class="btn btn-primary" aria-label="Download on the App Store" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            App Store
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.appscendlabs.cutphase&pcampaignid=web_share" class="btn btn-outline" aria-label="Get it on Google Play" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/>
            </svg>
            Google Play
          </a>
        </div>
        <p class="hero-note">Free to download · No credit card required</p>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="phone-wrapper">
          <img
            src="/images/mockup-04.png"
            alt="CutPhase app interface showing phase-based nutrition tracking"
            class="hero-phone"
            width="1003"
            height="1200"
            loading="eager"
            decoding="sync"
            fetchpriority="high"
          />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero {
    min-height: calc(100svh - 60px);
    display: flex;
    align-items: center;
    padding-block: var(--section-pad);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle at center, rgba(var(--accent-rgb), 0.04) 0%, transparent 62%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    max-width: 580px;
  }

  h1 {
    margin-bottom: 20px;
  }

  h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-sub {
    font-size: 1.0625rem;
    max-width: 480px;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .hero-note {
    font-size: 0.8125rem;
    color: var(--muted-dim);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .phone-wrapper {
    position: relative;
    display: inline-flex;
    justify-content: center;
  }

  .hero-phone {
    width: 420px;
    height: auto;
    position: relative;
    z-index: 1;
    animation: float 8s ease-in-out infinite;
    will-change: transform;
    filter: drop-shadow(0 32px 64px rgba(0, 0, 0, 0.6));
  }

  @keyframes float {
    0%, 100% { transform: translateX(12%) translateY(0); }
    50%       { transform: translateX(12%) translateY(-12px); }
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 52px;
      text-align: center;
    }

    .hero-text {
      align-items: center;
      max-width: 100%;
    }

    .hero-sub {
      max-width: 520px;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .hero-phone {
      width: 210px;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
