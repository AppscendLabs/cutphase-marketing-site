---
---

<header class="header" role="banner">
  <div class="header-inner container">

    <a href="#top" class="logo" aria-label="CutPhase home">
      <img
        src="/images/logo-mark.png"
        alt="CutPhase logo"
        class="logo-icon"
        height="56"
        width="56"
        loading="eager"
      />
      <span class="logo-name">CutPhase</span>
    </a>

    <nav class="header-nav" aria-label="Primary navigation">
      <a href="#how-it-works">How it works</a>
      <a href="#features">Features</a>
    </nav>

    <a href="#" class="btn btn-outline btn-sm" aria-label="Download CutPhase">
      Download
    </a>

  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 72px;
    display: flex;
    align-items: center;
    background: rgba(10, 10, 10, 0.82);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    margin-right: auto;
  }

  .logo-icon {
    height: 56px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .logo-name {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .header-nav a {
    font-size: 1.0625rem;
    color: var(--muted);
    transition: color 0.15s ease;
    letter-spacing: -0.01em;
  }

  .header-nav a:hover {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .header-nav {
      display: none;
    }
  }
</style>
