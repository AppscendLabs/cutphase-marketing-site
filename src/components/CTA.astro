<section class="cta" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta-card fade-up">

      <div class="cta-content">
        <span class="label">Get Started</span>
        <h2 id="cta-heading">
          Your results aren't random.<br />
          They're built with structure.
        </h2>
        <p>
          Join thousands of people using CutPhase to finally make their nutrition work.
          Free to download. No guesswork required.
        </p>
      </div>

      <div class="cta-actions">
        <div class="cta-buttons">
          <a href="https://apps.apple.com/us/app/cutphase/id6756089854" class="btn btn-primary" aria-label="Download CutPhase on the App Store" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            App Store
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.appscendlabs.cutphase&pcampaignid=web_share" class="btn btn-outline" aria-label="Download CutPhase on Google Play" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.6.37.6 1.23 0 1.6l-14 8.5c-.66.5-1.6.03-1.6-.8z"/>
            </svg>
            Google Play
          </a>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: var(--section-pad);
    border-top: 1px solid var(--border);
  }

  .cta-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 64px 60px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 0% 50%, rgba(var(--accent-rgb), 0.04) 0%, transparent 55%);
    pointer-events: none;
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .cta-content .label {
    margin-bottom: 14px;
  }

  .cta-content h2 {
    margin-bottom: 14px;
    font-size: clamp(1.5rem, 2.5vw, 2.1rem);
  }

  .cta-content p {
    font-size: 1rem;
    max-width: 380px;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
  }


  @media (max-width: 900px) {
    .cta-card {
      grid-template-columns: 1fr;
      padding: 48px 36px;
      gap: 40px;
    }

    .cta-buttons {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  @media (max-width: 480px) {
    .cta-card {
      padding: 36px 24px;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
