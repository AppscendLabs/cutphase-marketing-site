---
const features = [
  {
    title: 'Phase-Based Nutrition',
    description:
      'Every macro target is built for your phase. Cut calories are different from bulk calories—CutPhase knows the difference.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="5" rx="2"/><rect x="3" y="10" width="18" height="5" rx="2"/><rect x="3" y="17" width="18" height="4" rx="2"/></svg>`,
  },
  {
    title: 'Smart Meal Planning',
    description:
      'Meals built around your phase, not a generic template. No guesswork, no starting from scratch every Monday.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/><path d="M8 6v12"/></svg>`,
  },
  {
    title: 'Progress Tracking',
    description:
      'See your numbers move in real time. Track weight, macros, and phase milestones—all in one place.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    title: 'Adaptive Phases',
    description:
      'Your body changes. CutPhase adjusts your targets as you hit milestones so the plan stays accurate.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>`,
  },
];
---

<section class="features" id="features" aria-labelledby="features-heading">
  <div class="container">

    <div class="section-header fade-up">
      <span class="label">Features</span>
      <h2 id="features-heading">Everything your nutrition needs.</h2>
    </div>

    <ul class="feature-grid" aria-label="CutPhase features">
      {features.map((feature, i) => (
        <li class={`feature-card fade-up fade-up-delay-${i + 1}`}>
          <div class="feature-icon" aria-hidden="true">
            <Fragment set:html={feature.icon} />
          </div>
          <div class="feature-body">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .features {
    padding-block: var(--section-pad);
    border-top: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 48px;
  }

  .section-header h2 {
    max-width: 380px;
    margin-top: 6px;
  }

  .feature-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .feature-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    cursor: default;
  }

  .feature-card:hover {
    background: var(--card-hover);
    border-color: var(--border-hover);
    transform: translateY(-3px);
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    border-radius: 10px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .feature-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-body p {
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .feature-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .feature-card {
      padding: 26px 22px;
    }
  }
</style>
